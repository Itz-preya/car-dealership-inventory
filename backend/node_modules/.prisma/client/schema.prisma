datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     String @default("USER")
}

model Vehicle {
  id       String @id @default(uuid())
  make     String
  model    String
  year     Int
  price    Float
  status   String @default("AVAILABLE")
  quantity Int    @default(0)
}
